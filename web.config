<?xml version="1.0" encoding="utf-8"?>

<configuration>

  <system.webServer>

    <defaultDocument enabled="true">

      <files>

        <clear />

        <add value="index.html" />

      </files>

    </defaultDocument>



    <rewrite>

      <rules>

        <!-- monime POST on return pages → 303 GET (IIS static only serves GET) -->

        <rule name="MonimePostToGet" stopProcessing="true">

          <match url="^(checkout-success|checkout-cancelled|payment-success|payment-cancelled)\.html$" ignoreCase="true" />

          <conditions>

            <add input="{REQUEST_METHOD}" pattern="^POST$" />

          </conditions>

          <action type="Redirect" url="{R:0}" appendQueryString="true" redirectType="SeeOther" />

        </rule>

      </rules>

    </rewrite>

  </system.webServer>

  <system.web>

    <compilation tempDirectory="E:\Inetpub\vhosts\kns.edu.sl\tmp" />

  </system.web>

</configuration>

