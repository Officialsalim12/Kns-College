#!/bin/sh
# Strips Cursor agent attribution from commit messages (optional hook).
# Enable once per clone: git config core.hooksPath .githooks
if [ -f "$1" ]; then
    sed -i.bak '/cursoragent@cursor\.com/d;/Co-authored-by:.*[Cc]ursor/d;/Made-with:.*[Cc]ursor/d' "$1" 2>/dev/null ||
    sed -i '/cursoragent@cursor\.com/d;/Co-authored-by:.*[Cc]ursor/d;/Made-with:.*[Cc]ursor/d' "$1" 2>/dev/null
    rm -f "$1.bak"
fi
